    "@dfinity/candid": "^2.1.3",
    "@dfinity/principal": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "@vitejs/plugin-react": "^4.0.1",
    "dotenv": "^16.3.1",
    "sass": "^1.63.6",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.1.3",
    "vite": "^7.0.3",
    "vite-plugin-environment": "^1.1.3"
